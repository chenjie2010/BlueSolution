          </serviceCredentials>
          <serviceThrottling maxConcurrentCalls="5000" maxConcurrentSessions="5000" maxConcurrentInstances="5000" />
        </behavior>
        <behavior name="behaviorConfig">
          <serviceMetadata />
          <serviceDebug includeExceptionDetailInFaults="true" />
